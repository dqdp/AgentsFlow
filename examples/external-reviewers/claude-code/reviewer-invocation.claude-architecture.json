{
  "provider": "claude-code",
  "reviewer_role": "architecture",
  "billing_mode": "subscription-local",
  "api_key_usage_forbidden": true,
  "context_policy": {
    "start_mode": "fresh_context",
    "fork_conversation_context": false,
    "session_persistence": false,
    "input_mode": "review_packet"
  },
  "forbidden_env_checked": [
    "ANTHROPIC_API_KEY",
    "ANTHROPIC_AUTH_TOKEN",
    "ANTHROPIC_BASE_URL",
    "CLAUDE_CODE_USE_BEDROCK",
    "CLAUDE_CODE_USE_VERTEX"
  ],
  "command": "claude -p <prompt> --output-format json --permission-mode plan --tools \"\" --model opus --effort max --max-turns 3 --no-session-persistence",
  "execution_mode": "real",
  "permission_mode": "plan",
  "sandbox_mode": "require_escalated",
  "tools": "",
  "output_format": "json",
  "requested_model": "opus",
  "requested_effort": "max",
  "provider_models_used": [
    "claude-opus-latest"
  ],
  "provider_model_usage": {},
  "provider_total_cost_usd": 0.0,
  "provider_service_tier": "<provider-reported-service-tier>",
  "provider_speed": "<provider-reported-speed>",
  "max_turns": 3,
  "timeout_seconds": 900,
  "input_hash": "sha256:<review-packet>",
  "prompt_hash": "sha256:<rendered-prompt>",
  "review_prompt_contract_hash": "sha256:<review-prompt-contract>",
  "role_contract_hash": "sha256:<role-contract>",
  "rubric_hash": "sha256:<rubric>",
  "schema_hash": "sha256:<reviewer-schema>",
  "started_at": "<iso8601>",
  "finished_at": "<iso8601>",
  "exit_code": 0,
  "raw_output_path": "reviewer-report.claude-architecture.raw.json",
  "raw_output_hash": "sha256:<raw-provider-output>",
  "normalized_output_path": "reviewer-report.claude-architecture.json",
  "normalized_output_hash": "sha256:<normalized-reviewer-report>",
  "normalization": {
    "method": "deterministic-extraction",
    "source_path": "reviewer-report.claude-architecture.raw.json",
    "source_hash": "sha256:<raw-provider-output>",
    "output_path": "reviewer-report.claude-architecture.json",
    "output_hash": "sha256:<normalized-reviewer-report>",
    "schema_validation": "passed",
    "normalized_by": "scripts/reviewers/run_external_reviewer.py"
  }
}
