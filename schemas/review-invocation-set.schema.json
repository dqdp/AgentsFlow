{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/agentsflow/review-invocation-set.schema.json",
  "title": "Review Invocation Set",
  "type": "object",
  "required": [
    "artifact_kind",
    "review_prompt_contract",
    "status",
    "provider_model_families",
    "reviewers"
  ],
  "additionalProperties": true,
  "properties": {
    "artifact_kind": {
      "const": "review_invocation_set"
    },
    "review_prompt_contract": {
      "type": "string",
      "minLength": 1
    },
    "review_prompt_contract_hash": {
      "type": "string"
    },
    "status": {
      "enum": ["predeclared", "completed", "failed"]
    },
    "started_at": {
      "type": "string"
    },
    "finished_at": {
      "type": "string"
    },
    "runner_scheduling": {
      "enum": ["external-first-async"]
    },
    "provider_model_families": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "reviewers": {
      "type": "array",
      "minItems": 0,
      "maxItems": 8,
      "items": {
        "type": "object",
        "required": [
          "reviewer",
          "provider",
          "model_family",
          "packet_path",
          "report_path",
          "status"
        ],
        "additionalProperties": true,
        "properties": {
          "reviewer": {
            "type": "string"
          },
          "provider": {
            "enum": ["internal-agent", "claude-code"]
          },
          "model_family": {
            "type": "string",
            "minLength": 1
          },
          "evidence_model_family": {
            "type": "string",
            "minLength": 1
          },
          "packet_path": {
            "type": "string",
            "minLength": 1
          },
          "report_path": {
            "type": "string",
            "minLength": 1
          },
          "raw_output_path": {
            "type": "string"
          },
          "raw_output_hash": {
            "type": "string"
          },
          "invocation_metadata_path": {
            "type": "string"
          },
          "normalized_output_hash": {
            "type": "string"
          },
          "packet_hash": {
            "type": "string"
          },
          "report_hash": {
            "type": "string"
          },
          "status": {
            "enum": [
              "predeclared",
              "report-present",
              "waiting-for-report",
              "running",
              "invoked",
              "timed-out",
              "failed"
            ]
          },
          "execution_mode": {
            "enum": ["real", "mock"]
          },
          "error": {
            "type": "string"
          }
        }
      }
    },
    "error": {
      "type": "string"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "status": {
            "const": "completed"
          }
        },
        "required": ["status"]
      },
      "then": {
        "required": ["started_at", "finished_at"],
        "properties": {
          "reviewers": {
            "minItems": 1,
            "items": {
              "type": "object",
              "properties": {
                "status": {
                  "enum": ["report-present", "invoked"]
                }
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "reviewers": {
            "contains": {
              "type": "object",
              "properties": {
                "provider": {
                  "const": "claude-code"
                }
              },
              "required": ["provider"]
            }
          }
        },
        "required": ["reviewers"]
      },
      "then": {
        "required": ["runner_scheduling"],
        "properties": {
          "runner_scheduling": {
            "const": "external-first-async"
          }
        }
      }
    }
  ]
}
