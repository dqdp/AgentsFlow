{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AgentsFlow Workflow Binding",
  "type": "object",
  "required": [
    "workflow",
    "extends",
    "gates"
  ],
  "additionalProperties": true,
  "properties": {
    "workflow": {
      "type": "string"
    },
    "extends": {
      "type": "string"
    },
    "agentsflow_version": {
      "type": [
        "string",
        "number"
      ]
    },
    "binding": {
      "type": "object"
    },
    "gates": {
      "type": "object"
    },
    "behavior_bindings": {
      "type": "object"
    },
    "review": {
      "type": "object"
    }
  }
}