{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AgentsFlow Workflow Binding",
  "type": "object",
  "required": [
    "workflow",
    "extends",
    "agentsflow_version",
    "binding",
    "risk_surface_policy",
    "gates",
    "evidence_policy"
  ],
  "additionalProperties": true,
  "properties": {
    "workflow": {
      "type": "string"
    },
    "extends": {
      "type": "string"
    },
    "agentsflow_version": {
      "type": [
        "string",
        "number"
      ]
    },
    "strictness": {
      "type": "string",
      "enum": ["L0", "L1", "L2", "L3", "L4"]
    },
    "strictness_source": {
      "type": "string",
      "enum": ["workflow_default", "project_override", "task_override", "legacy_selected"]
    },
    "strictness_override_reason": {
      "type": "string",
      "minLength": 1
    },
    "binding": {
      "type": "object"
    },
    "gates": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": [
          "extends",
          "manifest",
          "runner"
        ],
        "additionalProperties": true,
        "properties": {
          "extends": {
            "type": "string"
          },
          "manifest": {
            "type": "string"
          },
          "runner": {
            "type": "string"
          }
        }
      }
    },
    "behavior_bindings": {
      "type": "object"
    },
    "risk_surface_policy": {
      "type": "object",
      "required": [
        "catalog_source",
        "project_default_surfaces",
        "project_local_surfaces",
        "failure_path_matrix_required_when"
      ],
      "additionalProperties": true,
      "properties": {
        "catalog_source": {
          "type": "string"
        },
        "project_default_surfaces": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "pattern": "\\S"
          }
        },
        "project_local_surfaces": {
          "type": "array"
        },
        "failure_path_matrix_required_when": {
          "type": "array",
                  "items": {
                    "type": "string",
                    "minLength": 1,
                    "pattern": "\\S"
                  },
          "minItems": 1
        }
      }
    },
    "evidence_policy": {
      "type": "object",
      "required": ["structured_command_evidence_required", "freshness"],
      "additionalProperties": true,
      "properties": {
        "structured_command_evidence_required": {
          "const": true
        },
        "freshness": {
          "type": "object",
          "required": [
            "material_change_id_required",
            "green_gate_after_latest_material_change_required",
            "review_packet_after_latest_green_gate_required",
            "stale_evidence_must_be_marked_or_excluded"
          ],
          "additionalProperties": true,
          "properties": {
            "material_change_id_required": {
              "const": true
            },
            "green_gate_after_latest_material_change_required": {
              "const": true
            },
            "review_packet_after_latest_green_gate_required": {
              "const": true
            },
            "stale_evidence_must_be_marked_or_excluded": {
              "const": true
            }
          }
        }
      }
    },
    "review_cycle": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "max_review_cycles": {
          "type": "integer",
          "minimum": 3
        }
      }
    },
    "review": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "topology": {
          "type": "string",
          "enum": [
            "none",
            "homogeneous-dual",
            "homogeneous-plus-focused",
            "heterogeneous-variable"
          ]
        },
        "topology_source": {
          "type": "string",
          "enum": ["project_policy", "risk_surface_profile", "human_decision"]
        },
        "selected_risk_surfaces": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "escalation_reason": {
          "type": "string",
          "minLength": 1
        },
        "reviewers": {
          "type": "array",
                  "items": {
                    "type": "string",
                    "minLength": 1,
                    "pattern": "\\S"
                  },
          "maxItems": 8
        },
        "composition": {
          "type": "string",
          "enum": [
            "homogeneous",
            "homogeneous-plus-focused",
            "heterogeneous"
          ]
        },
        "prompt_policy": {
          "type": "object"
        },
        "focus_zones": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["reviewer", "role", "primary_focus"],
            "additionalProperties": true,
            "properties": {
              "reviewer": {
                "type": "string"
              },
              "role": {
                "type": "string"
              },
              "primary_focus": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          }
        },
        "context_policy": {
          "type": "object",
          "required": ["start_mode", "fork_conversation_context"],
          "additionalProperties": true,
          "properties": {
            "start_mode": {
              "const": "fresh_context"
            },
            "fork_conversation_context": {
              "const": false
            }
          }
        }
      },
      "allOf": [
        {
          "if": {
            "required": ["topology"],
            "properties": {
              "topology": {
                "not": {
                  "const": "none"
                }
              }
            }
          },
          "then": {
            "required": ["reviewers", "composition", "prompt_policy", "context_policy"],
            "properties": {
              "topology": {
                "not": {
                  "const": "single-reviewer"
                }
              },
              "reviewers": {
                "minItems": 2
              }
            }
          }
        },
        {
          "if": {
            "required": ["composition"],
            "properties": {
              "composition": {
                "const": "homogeneous"
              }
            }
          },
          "then": {
            "properties": {
              "reviewers": {
                "minItems": 2,
                "maxItems": 2
              },
              "prompt_policy": {
                "required": ["same_prompt", "same_packet", "same_rubric", "same_output_schema"],
                "properties": {
                  "same_prompt": {
                    "const": true
                  },
                  "same_packet": {
                    "const": true
                  },
                  "same_rubric": {
                    "const": true
                  },
                  "same_output_schema": {
                    "const": true
                  }
                }
              }
            }
          }
        },
        {
          "if": {
            "required": ["composition"],
            "properties": {
              "composition": {
                "const": "homogeneous-plus-focused"
              }
            }
          },
          "then": {
            "required": ["focus_zones", "topology_source", "selected_risk_surfaces", "escalation_reason"],
            "properties": {
              "reviewers": {
                "minItems": 3,
                "maxItems": 8
              },
              "selected_risk_surfaces": {
                "minItems": 1
              },
              "prompt_policy": {
                "required": [
                  "baseline_same_prompt",
                  "focused_reviewers_require_explicit_focus_zone",
                  "focus_zones_may_overlap",
                  "all_reviewers_must_report_p0_p1_outside_focus"
                ],
                "properties": {
                  "baseline_same_prompt": {
                    "const": true
                  },
                  "focused_reviewers_require_explicit_focus_zone": {
                    "const": true
                  },
                  "focus_zones_may_overlap": {
                    "const": true
                  },
                  "all_reviewers_must_report_p0_p1_outside_focus": {
                    "const": true
                  }
                }
              }
            }
          }
        },
        {
          "if": {
            "required": ["composition"],
            "properties": {
              "composition": {
                "const": "heterogeneous"
              }
            }
          },
          "then": {
            "required": ["focus_zones", "topology_source", "selected_risk_surfaces", "escalation_reason"],
            "properties": {
              "reviewers": {
                "minItems": 3,
                "maxItems": 8
              },
              "selected_risk_surfaces": {
                "minItems": 1
              },
              "prompt_policy": {
                "required": [
                  "focus_prompts_required",
                  "focus_zones_may_overlap",
                  "all_reviewers_must_report_p0_p1_outside_focus"
                ],
                "properties": {
                  "focus_prompts_required": {
                    "const": true
                  },
                  "focus_zones_may_overlap": {
                    "const": true
                  },
                  "all_reviewers_must_report_p0_p1_outside_focus": {
                    "const": true
                  }
                }
              }
            }
          }
        }
      ]
    }
  },
  "allOf": [
    {
      "if": {
        "required": ["strictness"]
      },
      "then": {
        "required": ["strictness_source", "strictness_override_reason"],
        "properties": {
          "strictness_source": {
            "enum": ["project_override", "task_override", "legacy_selected"]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "strictness_source": {
            "enum": ["project_override", "task_override", "legacy_selected"]
          }
        },
        "required": ["strictness_source"]
      },
      "then": {
        "required": ["strictness", "strictness_override_reason"]
      }
    }
  ]
}
