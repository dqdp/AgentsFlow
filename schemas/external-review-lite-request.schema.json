{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/agentsflow/external-review-lite-request.schema.json",
  "title": "AgentsFlow External Review Lite Request",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "version",
    "artifact_kind",
    "context_mode",
    "provider",
    "reviewer",
    "run_id",
    "material_change_id",
    "review_goal",
    "branch",
    "changed_files",
    "dirty_worktree",
    "artifacts",
    "context_policy",
    "forbidden_actions",
    "output_schema"
  ],
  "properties": {
    "version": {"type": "integer", "const": 1},
    "artifact_kind": {"const": "external_review_lite_request"},
    "context_mode": {"const": "lite"},
    "provider": {"const": "claude-code"},
    "reviewer": {
      "type": "object",
      "required": ["id", "role"],
      "additionalProperties": true,
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "role": {"type": "string", "minLength": 1}
      }
    },
    "run_id": {"type": "string", "minLength": 1},
    "material_change_id": {"type": "string", "minLength": 1},
    "review_goal": {"type": "string", "minLength": 1, "pattern": "\\S"},
    "branch": {
      "type": "object",
      "required": ["base_ref", "head_ref", "base_commit", "head_commit"],
      "additionalProperties": true,
      "properties": {
        "base_ref": {"type": "string", "minLength": 1},
        "head_ref": {"type": "string", "minLength": 1},
        "base_commit": {"type": "string", "minLength": 1},
        "head_commit": {"type": "string", "minLength": 1}
      }
    },
    "changed_files": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "dirty_worktree": {
      "type": "object",
      "required": ["status", "included", "policy"],
      "additionalProperties": true,
      "properties": {
        "status": {"enum": ["clean", "dirty"]},
        "included": {"type": "boolean"},
        "policy": {"enum": ["clean_required", "include_staged_and_unstaged_diffs"]}
      }
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["kind", "path", "hash"],
        "additionalProperties": true,
        "properties": {
          "kind": {"type": "string", "minLength": 1},
          "path": {"type": "string", "minLength": 1},
          "bundle_path": {"type": "string", "minLength": 1},
          "source_path": {"type": "string"},
          "source_hash": {"type": "string"},
          "hash": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"}
        }
      }
    },
    "context_policy": {
      "type": "object",
      "required": ["start_mode", "fork_conversation_context", "allowed_context_sources"],
      "additionalProperties": true,
      "properties": {
        "start_mode": {"const": "fresh_context"},
        "fork_conversation_context": {"const": false},
        "allowed_context_sources": {
          "type": "array",
          "items": {"enum": ["review_request", "referenced_artifacts"]},
          "minItems": 2,
          "maxItems": 2,
          "uniqueItems": true
        }
      }
    },
    "forbidden_actions": {
      "type": "array",
      "items": {"type": "string"},
      "minItems": 1
    },
    "output_schema": {"const": "schemas/reviewer-report.schema.json"}
  }
}
