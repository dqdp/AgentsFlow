{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/agentsflow/reviewer-report.schema.json",
  "title": "AgentsFlow Reviewer Report",
  "type": "object",
  "additionalProperties": true,
  "required": ["reviewer", "summary", "findings"],
  "properties": {
    "reviewer": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id", "provider", "role"],
      "properties": {
        "id": {"type": "string"},
        "provider": {"type": "string"},
        "role": {"type": "string"},
        "model": {"type": "string"}
      }
    },
    "summary": {"type": "string"},
    "review_context": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "run_id": {"type": "string"},
        "material_change_id": {"type": "string"},
        "review_packet_path": {"type": "string"},
        "reviewer_instance_id": {"type": "string"}
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["id", "severity", "title", "evidence", "status"],
        "properties": {
          "id": {"type": "string"},
          "severity": {"enum": ["P0", "P1", "P2", "P3", "NOTE"]},
          "category": {"type": "string"},
          "title": {"type": "string"},
          "evidence": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
          "why_it_matters": {"type": "string"},
          "recommendation": {"type": "string"},
          "validated_severity": {"enum": ["P0", "P1", "P2", "P3", "NOTE"]},
          "blocker_path": {"type": "string", "minLength": 1},
          "acceptance_impact": {"type": "string", "minLength": 1},
          "mandatory_evidence_gap": {"type": "boolean"},
          "validation_rationale": {"type": "string", "minLength": 1},
          "calibration_reason": {"type": "string", "minLength": 1},
          "no_blocker_path_reason": {"type": "string", "minLength": 1},
          "status": {"const": "candidate-unvalidated"}
        },
        "allOf": [
          {
            "if": {
              "properties": {
                "severity": {"enum": ["P0", "P1"]}
              },
              "required": ["severity"]
            },
            "then": {
              "required": ["blocker_path", "acceptance_impact"]
            }
          }
        ]
      }
    },
    "requests_for_additional_verification": {
      "type": "array",
      "items": {"type": "object", "additionalProperties": true}
    },
    "self_declared_limitations": {
      "type": "array",
      "items": {"type": "string"}
    },
    "normalization": {
      "type": "object",
      "additionalProperties": true,
      "required": ["method", "source_path", "source_hash", "schema_validation", "normalized_by"],
      "properties": {
        "method": {
          "enum": [
            "native-json",
            "deterministic-extraction",
            "orchestrator-extraction",
            "model-structured-extraction"
          ]
        },
        "source_path": {"type": "string"},
        "source_hash": {"type": "string"},
        "schema_validation": {"const": "passed"},
        "normalized_by": {"type": "string"}
      }
    }
  }
}
