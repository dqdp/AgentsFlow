{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AgentsFlow Legacy Adoption Decision",
  "type": "object",
  "required": [
    "version",
    "adoption_mode",
    "legacy_handling",
    "human_approval"
  ],
  "properties": {
    "version": {
      "type": "integer"
    },
    "adoption_mode": {
      "type": "string",
      "enum": [
        "full-archive-rebuild",
        "knowledge-extraction",
        "minimal-patch-adapt",
        "shadow-pilot"
      ]
    },
    "reason": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "justification": {
      "type": "string"
    },
    "legacy_handling": {
      "type": "object",
      "required": [
        "no_ambiguous_coexistence",
        "final_authority_layer_required",
        "backup_required"
      ],
      "properties": {
        "backup_required": {
          "type": "boolean"
        },
        "archive_path": {
          "type": "string"
        },
        "final_authority_layer_required": {
          "type": "boolean"
        },
        "no_ambiguous_coexistence": {
          "type": "boolean"
        }
      },
      "additionalProperties": true
    },
    "legacy_artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "path",
          "classification"
        ],
        "properties": {
          "path": {
            "type": "string"
          },
          "classification": {
            "type": "string",
            "enum": [
              "active",
              "imported",
              "archived",
              "deprecated",
              "non-authoritative",
              "needs-human-decision"
            ]
          },
          "reason": {
            "type": "string"
          },
          "target": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      }
    },
    "human_approval": {
      "type": "object",
      "required": [
        "required",
        "status"
      ],
      "properties": {
        "required": {
          "type": "boolean"
        },
        "status": {
          "type": "string"
        },
        "approver": {
          "type": [
            "string",
            "null"
          ]
        },
        "approved_at": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": true
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "adoption_mode": {
            "const": "minimal-patch-adapt"
          }
        },
        "required": [
          "adoption_mode"
        ]
      },
      "then": {
        "required": [
          "justification"
        ]
      }
    }
  ]
}
