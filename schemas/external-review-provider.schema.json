{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/agentsflow/external-review-provider.schema.json",
  "title": "External Reviewer Provider",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "provider",
    "kind",
    "version",
    "billing",
    "execution",
    "context_policy",
    "permissions",
    "inputs",
    "outputs",
    "normalization"
  ],
  "properties": {
    "provider": {
      "const": "claude-code"
    },
    "kind": {
      "const": "external_reviewer_provider"
    },
    "version": {
      "type": "integer"
    },
    "billing": {
      "type": "object",
      "required": [
        "expected_mode",
        "forbid_api_key_usage",
        "fail_if_env_present"
      ],
      "properties": {
        "expected_mode": {
          "const": "subscription-local"
        },
        "forbid_api_key_usage": {
          "const": true
        },
        "fail_if_env_present": {
          "type": "array",
          "allOf": [
            {
              "contains": {
                "const": "ANTHROPIC_API_KEY"
              }
            },
            {
              "contains": {
                "const": "ANTHROPIC_AUTH_TOKEN"
              }
            },
            {
              "contains": {
                "const": "ANTHROPIC_BASE_URL"
              }
            },
            {
              "contains": {
                "const": "CLAUDE_CODE_USE_BEDROCK"
              }
            },
            {
              "contains": {
                "const": "CLAUDE_CODE_USE_VERTEX"
              }
            }
          ],
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "execution": {
      "type": "object",
      "required": ["command", "output_format", "permission_mode", "model", "effort", "use_bare_mode", "no_session_persistence"],
      "additionalProperties": true,
      "properties": {
        "command": {
          "const": "claude"
        },
        "output_format": {
          "const": "json"
        },
        "permission_mode": {
          "const": "plan"
        },
        "model": {
          "const": "opus"
        },
        "effort": {
          "const": "max"
        },
        "use_bare_mode": {
          "const": false
        },
        "no_session_persistence": {
          "const": true
        }
      }
    },
    "context_policy": {
      "type": "object",
      "required": ["start_mode", "fork_conversation_context", "session_persistence"],
      "additionalProperties": true,
      "properties": {
        "start_mode": {
          "const": "fresh_context"
        },
        "fork_conversation_context": {
          "const": false
        },
        "session_persistence": {
          "const": false
        },
        "input_mode": {
          "type": "string"
        }
      }
    },
    "permissions": {
      "type": "object",
      "required": [
        "write_files",
        "run_tests",
        "run_verification_instruments"
      ],
      "properties": {
        "write_files": {
          "const": false
        },
        "run_tests": {
          "const": false
        },
        "run_verification_instruments": {
          "const": false
        },
        "run_tools": {
          "const": false
        }
      },
      "additionalProperties": true
    },
    "inputs": {
      "type": "object",
      "additionalProperties": true
    },
    "outputs": {
      "type": "object",
      "additionalProperties": true
    },
    "normalization": {
      "type": "object",
      "required": ["require_schema_validation"],
      "additionalProperties": true,
      "properties": {
        "require_schema_validation": {
          "const": true
        }
      }
    }
  }
}
