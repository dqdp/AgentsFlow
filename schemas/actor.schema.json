{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AgentsFlow Actor Role",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "name",
    "class",
    "default_permissions"
  ],
  "properties": {
    "name": {
      "type": "string"
    },
    "class": {
      "enum": [
        "human",
        "main_orchestrating_agent",
        "planning_agent",
        "implementation_agent",
        "verification_gate",
        "review_agent",
        "fusion_agent",
        "script_tool_runner",
        "external_planning_provider"
      ]
    },
    "status": {
      "enum": [
        "active",
        "reserved",
        "future",
        "external"
      ]
    },
    "default_permissions": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "read": {
          "type": "boolean"
        },
        "write_specs": {
          "type": "boolean"
        },
        "modify_source": {
          "type": "boolean"
        },
        "run_verification_instruments": {
          "type": "boolean"
        },
        "run_tools": {
          "type": "boolean"
        },
        "launch_agents": {
          "type": "boolean"
        }
      }
    },
    "tool_exceptions": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}