{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/agentsflow/review-artifact-preparation.schema.json",
  "title": "Review Artifact Preparation",
  "type": "object",
  "required": [
    "version",
    "artifact_kind",
    "artifact_scope",
    "status",
    "review_prompt_contract",
    "source_context",
    "input_artifacts",
    "generated_artifacts",
    "reviewer_assignments",
    "validation"
  ],
  "additionalProperties": true,
  "properties": {
    "version": {
      "type": "integer"
    },
    "artifact_kind": {
      "const": "review_artifact_preparation"
    },
    "artifact_scope": {
      "type": "string",
      "enum": ["template", "example", "run"]
    },
    "status": {
      "enum": ["completed", "failed"]
    },
    "prepared_at": {
      "type": "string"
    },
    "review_prompt_contract": {
      "type": "object",
      "required": ["path", "hash"],
      "additionalProperties": true,
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "hash": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "source_context": {
      "type": "object",
      "required": ["dirty_policy", "worktree"],
      "additionalProperties": true,
      "properties": {
        "material_change_id": {
          "type": "string"
        },
        "dirty_policy": {
          "enum": ["fail-closed"]
        },
        "worktree": {
          "type": "object",
          "required": ["status_command", "status_entries", "included_dirty_paths", "excluded_dirty_paths"],
          "additionalProperties": true,
          "properties": {
            "status_command": {
              "type": "string"
            },
            "status_entries": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["path", "status"],
                "additionalProperties": true,
                "properties": {
                  "path": {
                    "type": "string",
                    "minLength": 1
                  },
                  "status": {
                    "type": "string",
                    "minLength": 1
                  }
                }
              }
            },
            "included_dirty_paths": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "excluded_dirty_paths": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["path", "reason"],
                "additionalProperties": true,
                "properties": {
                  "path": {
                    "type": "string",
                    "minLength": 1
                  },
                  "reason": {
                    "type": "string",
                    "minLength": 1
                  }
                }
              }
            }
          }
        }
      }
    },
    "input_artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "kind", "hash"],
        "additionalProperties": true,
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1
          },
          "kind": {
            "type": "string",
            "minLength": 1
          },
          "hash": {
            "type": "string",
            "minLength": 1
          },
          "required_by": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "generated_artifacts": {
      "type": "object",
      "required": ["review_packets", "rendered_prompts", "review_invocation_set"],
      "additionalProperties": true,
      "properties": {
        "shared_packet_content": {
          "type": "object",
          "required": ["path", "hash"],
          "additionalProperties": true,
          "properties": {
            "path": {
              "type": "string"
            },
            "hash": {
              "type": "string"
            }
          }
        },
        "review_packets": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["reviewer", "path", "hash"],
            "additionalProperties": true,
            "properties": {
              "reviewer": {
                "type": "string"
              },
              "path": {
                "type": "string"
              },
              "hash": {
                "type": "string"
              },
              "shared_packet_content_hash": {
                "type": "string"
              }
            }
          }
        },
        "rendered_prompts": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["reviewer", "path", "hash", "packet_hash", "schema_hash", "rubric_hash", "role_contract_hash"],
            "additionalProperties": true,
            "properties": {
              "reviewer": {
                "type": "string"
              },
              "path": {
                "type": "string"
              },
              "hash": {
                "type": "string"
              },
              "packet_hash": {
                "type": "string"
              },
              "schema_hash": {
                "type": "string"
              },
              "rubric_hash": {
                "type": "string"
              },
              "role_contract_hash": {
                "type": "string"
              }
            }
          }
        },
        "review_invocation_set": {
          "type": "object",
          "required": ["path", "status"],
          "additionalProperties": true,
          "properties": {
            "path": {
              "type": "string"
            },
            "status": {
              "enum": ["predeclared", "completed", "failed"]
            }
          }
        }
      }
    },
    "reviewer_assignments": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["reviewer", "provider", "model_family", "packet_path", "report_path"],
        "additionalProperties": true,
        "properties": {
          "reviewer": {
            "type": "string"
          },
          "provider": {
            "enum": ["internal-agent", "claude-code"]
          },
          "model_family": {
            "type": "string"
          },
          "packet_path": {
            "type": "string"
          },
          "report_path": {
            "type": "string"
          }
        }
      }
    },
    "validation": {
      "type": "object",
      "required": ["schema", "deterministic_script", "script_contract"],
      "additionalProperties": true,
      "properties": {
        "schema": {
          "type": "string"
        },
        "deterministic_script": {
          "const": "scripts/reviewers/prepare_review_set_artifacts.py"
        },
        "script_contract": {
          "const": "scripts/contracts/prepare_review_set_artifacts.yaml"
        }
      }
    },
    "error": {
      "type": "string"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "status": {
            "const": "completed"
          }
        },
        "required": ["status"]
      },
      "then": {
        "properties": {
          "input_artifacts": {
            "minItems": 1
          }
        }
      }
    }
  ]
}
