{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AgentsFlow Workflow Run",
  "type": "object",
  "required": ["version", "run_id", "workflow", "agentsflow_version", "binding", "status"],
  "properties": {
    "version": {"type": "integer"},
    "run_id": {"type": "string"},
    "workflow": {"type": "string"},
    "agentsflow_version": {"type": "string"},
    "binding": {"type": "string"},
    "strictness": {
      "type": "string",
      "enum": ["L0", "L1", "L2", "L3", "L4"]
    },
    "strictness_source": {
      "type": "string",
      "enum": ["workflow_default", "project_override", "task_override", "legacy_selected"]
    },
    "strictness_override_reason": {"type": "string", "minLength": 1},
    "review_topology": {"type": "string"},
    "status": {"type": "string"},
    "human_interaction": {"type": "object"},
    "artifacts": {
      "type": "object",
      "properties": {
        "root": {"type": "string", "minLength": 1}
      },
      "additionalProperties": true
    },
    "phase_evidence": {"type": "object"},
    "phase_guard": {
      "type": "object",
      "required": ["current_phase", "allowed_next_phases", "allowed_outputs"],
      "properties": {
        "current_phase": {"type": "string", "minLength": 1},
        "completed_phases": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        },
        "allowed_next_phases": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        },
        "allowed_outputs": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        },
        "draft_artifacts": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        },
        "forbidden_outputs_until_phase_exit": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["path", "until_phase", "reason"],
            "properties": {
              "path": {"type": "string", "minLength": 1},
              "until_phase": {"type": "string", "minLength": 1},
              "reason": {"type": "string", "minLength": 1}
            },
            "additionalProperties": true
          }
        },
        "blocked": {"type": "boolean"},
        "blocked_by": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        }
      },
      "additionalProperties": true
    },
    "phase_status": {"type": "array"}
  },
  "additionalProperties": true,
  "allOf": [
    {
      "if": {
        "required": ["strictness"]
      },
      "then": {
        "required": ["strictness_source"]
      }
    },
    {
      "if": {
        "required": ["strictness_source"]
      },
      "then": {
        "required": ["strictness"]
      }
    },
    {
      "if": {
        "properties": {
          "strictness_source": {
            "enum": ["project_override", "task_override", "legacy_selected"]
          }
        },
        "required": ["strictness_source"]
      },
      "then": {
        "required": ["strictness_override_reason"]
      }
    }
  ]
}
