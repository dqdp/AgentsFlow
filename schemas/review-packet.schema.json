{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/agentsflow/review-packet.schema.json",
  "title": "Review Packet",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "agentsflow_version",
    "workflow",
    "run_id",
    "reviewer_role",
    "reviewer_instance_id",
    "review_goal",
    "review_profile",
    "composition",
    "prompt_policy",
    "role_contract",
    "review_prompt_contract",
    "context_policy",
    "risk_surface_profile",
    "failure_path_matrix",
    "verification_gate_report",
    "evidence_freshness",
    "known_blockers",
    "forbidden_actions",
    "output_schema"
  ],
  "properties": {
    "agentsflow_version": {
      "type": "string"
    },
    "workflow": {
      "type": "string"
    },
    "run_id": {
      "type": "string"
    },
    "reviewer_role": {
      "type": "string"
    },
    "reviewer_instance_id": {
      "type": "string"
    },
    "provider": {
      "type": "string"
    },
    "review_goal": {
      "type": "string"
    },
    "review_profile": {
      "type": "string",
      "enum": [
        "homogeneous-dual",
        "homogeneous-plus-focused",
        "heterogeneous-variable",
        "collision-control"
      ]
    },
    "composition": {
      "type": "string",
      "enum": [
        "homogeneous",
        "homogeneous-plus-focused",
        "heterogeneous",
        "control"
      ]
    },
    "prompt_policy": {
      "type": "object"
    },
    "role_contract": {
      "type": "string"
    },
    "role_contract_hash": {
      "type": "string"
    },
    "review_prompt_contract": {
      "type": "object",
      "required": ["path", "schema"],
      "additionalProperties": true,
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "schema": {
          "type": "string"
        }
      }
    },
    "collision_control": {
      "type": ["object", "null"],
      "required": [
        "trigger",
        "collision_batch_id",
        "control_reviewer_count",
        "disputed_findings",
        "orchestrator_collision_reason",
        "evidence_references_checked"
      ],
      "additionalProperties": true,
      "properties": {
        "trigger": {
          "const": "rejected_or_downgraded_blocker_collision"
        },
        "collision_batch_id": {
          "type": "string",
          "minLength": 1
        },
        "control_reviewer_count": {
          "const": 2
        },
        "disputed_findings": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "finding_id",
              "original_severity",
              "source_reviewer_report",
              "orchestrator_action"
            ],
            "additionalProperties": true,
            "properties": {
              "finding_id": {
                "type": "string",
                "minLength": 1
              },
              "original_severity": {
                "enum": ["P0", "P1"]
              },
              "source_reviewer_report": {
                "type": "string",
                "minLength": 1
              },
              "orchestrator_action": {
                "enum": ["rejected", "downgraded"]
              }
            }
          }
        },
        "orchestrator_collision_reason": {
          "type": "string",
          "minLength": 1
        },
        "evidence_references_checked": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1
        }
      }
    },
    "focus_zone": {
      "type": "object"
    },
    "context_policy": {
      "type": "object",
      "required": ["start_mode", "fork_conversation_context"],
      "additionalProperties": true,
      "properties": {
        "start_mode": {
          "const": "fresh_context"
        },
        "fork_conversation_context": {
          "const": false
        },
        "allowed_context_sources": {
          "type": "array",
          "items": {
            "enum": ["review_packet", "referenced_artifacts"]
          },
          "minItems": 2,
          "maxItems": 2,
          "uniqueItems": true
        }
      }
    },
    "changed_files": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "risk_surface_profile": {
      "type": "object",
      "required": ["selected_risk_surfaces", "review_topology_source"],
      "additionalProperties": true,
      "properties": {
        "selected_risk_surfaces": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "pattern": "\\S"
          }
        },
        "review_topology_source": {
          "type": "string",
          "enum": [
            "workflow_default",
            "project_policy",
            "risk_surface_profile",
            "human_decision"
          ]
        },
        "escalation_reason": {
          "type": "string"
        }
      }
    },
    "failure_path_matrix": {
      "type": "object",
      "required": ["path", "rows"],
      "additionalProperties": true,
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1,
          "pattern": "\\S"
        },
        "rows": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "risk_surface", "path_class", "evidence_binding"],
            "additionalProperties": true,
            "allOf": [
              {
                "if": {
                  "properties": {
                    "status": {"const": "deferred"}
                  },
                  "required": ["status"]
                },
                "then": {
                  "required": ["deferral"]
                }
              }
            ],
            "properties": {
              "id": {
                "type": "string",
                "minLength": 1,
                "pattern": "\\S"
              },
              "risk_surface": {
                "type": "string",
                "minLength": 1,
                "pattern": "\\S"
              },
              "path_class": {
                "type": "string",
                "minLength": 1,
                "pattern": "\\S"
              },
              "evidence_binding": {
                "type": "string",
                "minLength": 1,
                "pattern": "\\S"
              },
              "status": {
                "type": "string",
                "enum": ["covered", "deferred", "not_applicable"]
              },
              "deferral": {
                "type": "object",
                "required": ["residual_risk", "approved_by", "approval_artifact"],
                "additionalProperties": true,
                "properties": {
                  "residual_risk": {
                    "type": "string",
                    "minLength": 1,
                    "pattern": "\\S"
                  },
                  "approved_by": {
                    "type": "string",
                    "minLength": 1,
                    "pattern": "\\S"
                  },
                  "approval_artifact": {
                    "type": "string",
                    "minLength": 1,
                    "pattern": "\\S"
                  },
                  "constraints": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "minLength": 1,
                      "pattern": "\\S"
                    },
                    "minItems": 1
                  }
                }
              }
            }
          }
        }
      }
    },
    "verification_gate_report": {
      "type": "object",
      "required": ["path"],
      "additionalProperties": true,
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1,
          "pattern": "\\S"
        },
        "summary": {
          "type": "string"
        }
      }
    },
    "evidence_freshness": {
      "type": "object",
      "required": [
        "material_change_id",
        "latest_green_gate",
        "review_packet_generated_after_latest_green_gate",
        "stale_evidence_marked_or_excluded"
      ],
      "additionalProperties": true,
      "properties": {
        "material_change_id": {
          "type": "string",
          "minLength": 1,
          "pattern": "\\S"
        },
        "latest_green_gate": {
          "type": "string",
          "minLength": 1,
          "pattern": "\\S"
        },
        "review_packet_generated_after_latest_green_gate": {
          "const": true
        },
        "stale_evidence_marked_or_excluded": {
          "const": true
        }
      }
    },
    "known_blockers": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "forbidden_actions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "output_schema": {
      "type": "string"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "risk_surface_profile": {
            "properties": {
              "selected_risk_surfaces": {
                "minItems": 1
              }
            },
            "required": ["selected_risk_surfaces"]
          }
        },
        "required": ["risk_surface_profile"]
      },
      "then": {
        "properties": {
          "failure_path_matrix": {
            "properties": {
              "rows": {
                "minItems": 1
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "review_profile": {
            "enum": ["homogeneous-plus-focused", "heterogeneous-variable"]
          }
        },
        "required": ["review_profile"]
      },
      "then": {
        "properties": {
          "risk_surface_profile": {
            "required": [
              "selected_risk_surfaces",
              "review_topology_source",
              "escalation_reason"
            ],
            "properties": {
              "selected_risk_surfaces": {
                "minItems": 1
              },
              "review_topology_source": {
                "enum": ["project_policy", "risk_surface_profile", "human_decision"]
              },
              "escalation_reason": {
                "minLength": 1
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "review_profile": {
            "const": "collision-control"
          }
        },
        "required": ["review_profile"]
      },
      "then": {
        "required": ["collision_control"],
        "properties": {
          "collision_control": {
            "type": "object"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "composition": {
            "const": "heterogeneous"
          }
        },
        "required": ["composition"]
      },
      "then": {
        "required": ["focus_zone"]
      }
    },
    {
      "if": {
        "properties": {
          "composition": {
            "const": "homogeneous-plus-focused"
          },
          "reviewer_instance_id": {
            "not": {
              "enum": ["generalist-a", "generalist-b"]
            }
          }
        },
        "required": ["composition", "reviewer_instance_id"]
      },
      "then": {
        "required": ["focus_zone"]
      }
    }
  ]
}
