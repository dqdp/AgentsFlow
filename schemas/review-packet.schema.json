{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/agentsflow/review-packet.schema.json",
  "title": "Review Packet",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "agentsflow_version",
    "workflow",
    "run_id",
    "reviewer_role",
    "reviewer_instance_id",
    "review_goal",
    "review_profile",
    "composition",
    "prompt_policy",
    "role_contract",
    "review_prompt_contract",
    "context_policy",
    "forbidden_actions",
    "output_schema"
  ],
  "properties": {
    "agentsflow_version": {
      "type": "string"
    },
    "workflow": {
      "type": "string"
    },
    "run_id": {
      "type": "string"
    },
    "reviewer_role": {
      "type": "string"
    },
    "reviewer_instance_id": {
      "type": "string"
    },
    "provider": {
      "type": "string"
    },
    "review_goal": {
      "type": "string"
    },
    "review_profile": {
      "type": "string",
      "enum": [
        "homogeneous-dual",
        "homogeneous-plus-focused",
        "heterogeneous-variable",
        "collision-control"
      ]
    },
    "composition": {
      "type": "string",
      "enum": [
        "homogeneous",
        "homogeneous-plus-focused",
        "heterogeneous",
        "control"
      ]
    },
    "prompt_policy": {
      "type": "object"
    },
    "role_contract": {
      "type": "string"
    },
    "role_contract_hash": {
      "type": "string"
    },
    "review_prompt_contract": {
      "type": "object",
      "required": ["path", "schema"],
      "additionalProperties": true,
      "properties": {
        "path": {
          "type": "string"
        },
        "schema": {
          "type": "string"
        }
      }
    },
    "collision_control": {
      "type": ["object", "null"],
      "required": [
        "trigger",
        "collision_batch_id",
        "control_reviewer_count",
        "disputed_findings",
        "orchestrator_collision_reason",
        "evidence_references_checked"
      ],
      "additionalProperties": true,
      "properties": {
        "trigger": {
          "const": "rejected_or_downgraded_blocker_collision"
        },
        "collision_batch_id": {
          "type": "string",
          "minLength": 1
        },
        "control_reviewer_count": {
          "const": 2
        },
        "disputed_findings": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "finding_id",
              "original_severity",
              "source_reviewer_report",
              "orchestrator_action"
            ],
            "additionalProperties": true,
            "properties": {
              "finding_id": {
                "type": "string",
                "minLength": 1
              },
              "original_severity": {
                "enum": ["P0", "P1"]
              },
              "source_reviewer_report": {
                "type": "string",
                "minLength": 1
              },
              "orchestrator_action": {
                "enum": ["rejected", "downgraded"]
              }
            }
          }
        },
        "orchestrator_collision_reason": {
          "type": "string",
          "minLength": 1
        },
        "evidence_references_checked": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1
        }
      }
    },
    "focus_zone": {
      "type": "object"
    },
    "context_policy": {
      "type": "object",
      "required": ["start_mode", "fork_conversation_context"],
      "additionalProperties": true,
      "properties": {
        "start_mode": {
          "const": "fresh_context"
        },
        "fork_conversation_context": {
          "const": false
        },
        "allowed_context_sources": {
          "type": "array",
          "items": {
            "enum": ["review_packet", "referenced_artifacts"]
          },
          "minItems": 2,
          "maxItems": 2,
          "uniqueItems": true
        }
      }
    },
    "changed_files": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "forbidden_actions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "output_schema": {
      "type": "string"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "review_profile": {
            "const": "collision-control"
          }
        },
        "required": ["review_profile"]
      },
      "then": {
        "required": ["collision_control"],
        "properties": {
          "collision_control": {
            "type": "object"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "composition": {
            "const": "heterogeneous"
          }
        },
        "required": ["composition"]
      },
      "then": {
        "required": ["focus_zone"]
      }
    }
  ]
}
