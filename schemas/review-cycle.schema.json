{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/agentsflow/review-cycle.schema.json",
  "title": "Review Cycle Policy",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "default_exit_when": {
      "enum": [
        "no_validated_blocking_findings",
        "workflow_defined",
        "human_decision"
      ]
    },
    "max_review_cycles": {
      "type": "integer",
      "minimum": 3
    },
    "max_review_cycles_required": {
      "type": "boolean"
    },
    "max_review_cycles_source": {
      "enum": [
        "project_policy",
        "workflow_binding",
        "project_policy_or_workflow_binding",
        "none"
      ]
    },
    "max_review_cycles_absent_means": {
      "enum": [
        "unlimited"
      ]
    },
    "rerun_review_on": {
      "type": "array",
      "items": {
        "enum": [
          "accepted_blocker_fixed",
          "mandatory_evidence_added",
          "contract_changed",
          "material_artifact_change",
          "verification_gate_materially_changed",
          "project_overlay_materially_changed",
          "human_requested",
          "workflow_requires_second_pass"
        ]
      }
    },
    "do_not_rerun_on": {
      "type": "array",
      "items": {
        "enum": [
          "nonblocking_findings_with_non_material_fixes_only",
          "duplicate_consolidation",
          "irrelevant_findings_rejected_with_reason",
          "fusion_rewording_only",
          "report_editorial_changes_only"
        ]
      }
    },
    "rerun_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "after_validated_blocker_or_mandatory_evidence_gap",
        "full_scope_inputs",
        "reviewer_instruction_must_include",
        "closure_only_review_allowed",
        "closure_only_review_counts_as_acceptance_gate"
      ],
      "properties": {
        "after_validated_blocker_or_mandatory_evidence_gap": {
          "enum": [
            "full_scope_blocker_and_evidence_sweep"
          ]
        },
        "full_scope_inputs": {
          "type": "array",
          "items": {
            "enum": [
              "latest_review_packet",
              "complete_current_diff",
              "latest_green_verification_evidence",
              "previous_validated_findings_and_fixes"
            ]
          }
        },
        "reviewer_instruction_must_include": {
          "type": "array",
          "items": {
            "enum": [
              "verify_closure_of_previous_validated_findings",
              "search_for_new_or_remaining_p0_p1_blockers_across_full_slice",
              "search_for_new_or_remaining_mandatory_evidence_gaps_across_full_slice"
            ]
          }
        },
        "closure_only_review_allowed": {
          "type": "boolean"
        },
        "closure_only_review_counts_as_acceptance_gate": {
          "const": false
        }
      }
    },
    "blocking_default": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "severities": {
          "type": "array",
          "items": {
            "enum": ["P0", "P1", "P2", "P3", "NOTE"]
          }
        },
        "missing_mandatory_evidence_blocks": {
          "type": "boolean"
        },
        "majority_cannot_override_candidate_blocker": {
          "type": "boolean"
        }
      }
    },
    "validation_required_for": {
      "type": "array",
      "items": {
        "enum": [
          "P0",
          "P1",
          "fusion_candidate_blockers",
          "mandatory_evidence_gaps",
          "human_decision_items"
        ]
      }
    },
    "final_states": {
      "type": "array",
      "items": {
        "enum": [
          "pass",
          "pass-with-notes",
          "needs-changes",
          "needs-verification-evidence",
          "human-decision-required",
          "blocked"
        ]
      }
    }
  }
}
