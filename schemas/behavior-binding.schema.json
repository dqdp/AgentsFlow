{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AgentsFlow Behavior Binding Manifest",
  "type": "object",
  "required": [
    "version",
    "contract",
    "bindings"
  ],
  "additionalProperties": true,
  "properties": {
    "version": {
      "type": [
        "integer",
        "number"
      ]
    },
    "contract": {
      "type": "string"
    },
    "bindings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "scenario",
          "required",
          "checks",
          "gates"
        ],
        "additionalProperties": true,
        "properties": {
          "id": {
            "type": "string"
          },
          "scenario": {
            "type": "string"
          },
          "required": {
            "type": "boolean"
          },
          "status": {
            "type": "string"
          },
          "source": {
            "type": "object"
          },
          "severity_if_unverified": {
            "type": "string"
          },
          "risk_surfaces": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "minItems": 1
          },
          "path_class": {
            "type": "string"
          },
          "evidence_class": {
            "type": "string",
            "enum": [
              "test",
              "script",
              "bdd_runner",
              "eval",
              "trace_assertion",
              "log_assertion",
              "static_analysis",
              "dynamic_analysis",
              "benchmark",
              "security_scan",
              "manual_evidence",
              "external_tool"
            ]
          },
          "failure_path_matrix_refs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "checks": {
            "type": "array",
            "minItems": 0,
            "items": {
              "type": "object",
              "required": [
                "id",
                "type"
              ],
              "additionalProperties": true
            }
          },
          "gates": {
            "type": "array",
            "minItems": 0,
            "items": {
              "type": "string"
            }
          }
        },
        "allOf": [
          {
            "if": {
              "properties": {
                "required": {
                  "const": true
                }
              },
              "required": [
                "required"
              ]
            },
            "then": {
              "properties": {
                "checks": {
                  "minItems": 1
                },
                "gates": {
                  "minItems": 1
                }
              }
            }
          }
        ]
      }
    }
  }
}
