{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AgentsFlow Behavior Binding Manifest",
  "type": "object",
  "required": [
    "version",
    "contract",
    "bindings"
  ],
  "additionalProperties": true,
  "properties": {
    "version": {
      "type": [
        "integer",
        "number"
      ]
    },
    "contract": {
      "type": "string"
    },
    "bindings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "scenario",
          "required",
          "checks",
          "gates"
        ],
        "additionalProperties": true,
        "properties": {
          "id": {
            "type": "string"
          },
          "scenario": {
            "type": "string"
          },
          "required": {
            "type": "boolean"
          },
          "status": {
            "type": "string"
          },
          "source": {
            "type": "object"
          },
          "severity_if_unverified": {
            "type": "string"
          },
          "checks": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": [
                "id",
                "type"
              ],
              "additionalProperties": true
            }
          },
          "gates": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}