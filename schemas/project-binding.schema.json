{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AgentsFlow Project Binding",
  "type": "object",
  "required": [
    "name",
    "agentsflow_version",
    "paths"
  ],
  "additionalProperties": true,
  "properties": {
    "name": {
      "type": "string"
    },
    "agentsflow_version": {
      "type": [
        "string",
        "number"
      ]
    },
    "paths": {
      "type": "object",
      "required": [
        "docs_root",
        "agentsflow_root",
        "runs_root"
      ],
      "additionalProperties": true,
      "properties": {
        "docs_root": {
          "type": "string"
        },
        "adr_root": {
          "type": "string"
        },
        "agentsflow_root": {
          "type": "string"
        },
        "runs_root": {
          "type": "string"
        }
      }
    },
    "project_rules": {
      "type": "object"
    },
    "verification_defaults": {
      "type": "object"
    }
  }
}
