{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AgentsFlow Project Operating Decisions",
  "type": "object",
  "required": [
    "version",
    "source",
    "interview_state",
    "project_context",
    "workflow_defaults",
    "risk_surface_policy",
    "verification_gate_policy",
    "review_policy",
    "review_cycle_policy",
    "authority_policy",
    "artifact_policy",
    "decision_log",
    "unresolved_questions"
  ],
  "additionalProperties": true,
  "properties": {
    "version": {
      "type": "integer"
    },
    "source": {
      "type": "object",
      "required": ["collection_mode"],
      "additionalProperties": true,
      "properties": {
        "collection_mode": {
          "type": "string",
          "enum": ["agent-led-dialogue"]
        },
        "interviewer": {
          "type": "string"
        },
        "based_on_artifacts": {
          "type": "array",
          "items": {"type": "string"}
        },
        "raw_dialogue_reference": {
          "type": ["string", "null"]
        }
      }
    },
    "interview_state": {
      "type": "object",
      "required": ["status"],
      "additionalProperties": true,
      "properties": {
        "status": {
          "type": "string",
          "enum": ["draft", "confirmed", "needs-human-decision", "rejected"]
        },
        "confirmed_by": {
          "type": ["string", "null"]
        },
        "confirmation_summary": {
          "type": "string"
        }
      }
    },
    "project_context": {
      "type": "object",
      "additionalProperties": true
    },
    "workflow_defaults": {
      "type": "object",
      "additionalProperties": true
    },
    "risk_surface_policy": {
      "type": "object",
      "required": [
        "catalog_source",
        "project_default_surfaces",
        "project_local_surfaces",
        "selection_rule",
        "failure_path_matrix_required_when",
        "required_path_class_policy",
        "review_topology_policy"
      ],
      "additionalProperties": true,
      "properties": {
        "catalog_source": {
          "type": "string",
          "minLength": 1
        },
        "project_default_surfaces": {
          "type": "array",
          "items": {"type": "string"}
        },
        "project_local_surfaces": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "definition", "required_path_classes"],
            "additionalProperties": true,
            "properties": {
              "name": {"type": "string"},
              "definition": {"type": "string"},
              "required_path_classes": {
                "type": "array",
                "items": {"type": "string"},
                "minItems": 1
              }
            }
          }
        },
        "selection_rule": {
          "type": "string",
          "minLength": 1
        },
        "failure_path_matrix_required_when": {
          "type": "array",
          "items": {"type": "string"},
          "minItems": 1
        },
        "required_path_class_policy": {
          "type": "object",
          "additionalProperties": true
        },
        "review_topology_policy": {
          "type": "object",
          "required": ["default", "escalate_when_selected_surfaces_include", "escalation_rule"],
          "additionalProperties": true,
          "properties": {
            "default": {
              "type": "string",
              "enum": ["homogeneous-dual", "homogeneous-plus-focused", "heterogeneous-variable"]
            },
            "escalate_when_selected_surfaces_include": {
              "type": "array",
              "items": {"type": "string"}
            },
            "escalation_rule": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "verification_gate_policy": {
      "type": "object",
      "required": ["mandatory_blockers", "evidence_required"],
      "additionalProperties": true,
      "properties": {
        "mandatory_blockers": {
          "type": "array",
          "items": {"type": "string"}
        },
        "advisory_checks": {
          "type": "array",
          "items": {"type": "string"}
        },
        "red_green_required_for_implementation": {
          "type": "boolean"
        },
        "evidence_required": {
          "type": "array",
          "items": {"type": "string"}
        },
        "canonical_commands": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "review_policy": {
      "type": "object",
      "required": [
        "reviewer_count",
        "composition",
        "prompt_policy",
        "reviewer_roles",
        "context_policy",
        "read_only_by_default",
        "allow_external_reviewers",
        "allow_different_models",
        "candidate_findings_require_main_validation"
      ],
      "additionalProperties": true,
      "properties": {
        "reviewer_count": {
          "anyOf": [
            {
              "const": 0
            },
            {
              "type": "integer",
              "minimum": 2
            }
          ],
          "description": "0 means review is disabled. Enabled review gates require at least two reviewers."
        },
        "reviewer_roles": {
          "type": "array",
          "items": {"type": "string"}
        },
        "composition": {
          "type": "string",
          "enum": ["homogeneous", "homogeneous-plus-focused", "heterogeneous"]
        },
        "prompt_policy": {
          "type": "object",
          "additionalProperties": true
        },
        "focus_zones": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["role", "primary_focus"],
            "additionalProperties": true,
            "properties": {
              "role": {"type": "string"},
              "primary_focus": {
                "type": "array",
                "items": {"type": "string"}
              }
            }
          }
        },
        "context_policy": {
          "type": "object",
          "required": ["start_mode", "fork_conversation_context"],
          "additionalProperties": true,
          "properties": {
            "start_mode": {
              "const": "fresh_context"
            },
            "fork_conversation_context": {
              "const": false
            },
            "allowed_context_sources": {
              "type": "array",
              "items": {"type": "string"}
            }
          }
        },
        "read_only_by_default": {
          "const": true
        },
        "allow_external_reviewers": {
          "type": "boolean"
        },
        "allow_different_models": {
          "type": "boolean"
        },
        "provider_strategy": {
          "type": "object",
          "required": [
            "assignment_source",
            "default_internal_provider",
            "supported_external_providers",
            "unsupported_provider_behavior"
          ],
          "additionalProperties": true,
          "properties": {
            "assignment_source": {
              "const": "review_prompt_contract.reviewer_assignments"
            },
            "default_internal_provider": {
              "const": "internal-agent"
            },
            "supported_external_providers": {
              "type": "array",
              "items": {
                "enum": ["claude-code"]
              },
              "uniqueItems": true
            },
            "different_models_requires_assignments": {
              "type": "boolean"
            },
            "min_distinct_provider_model_families": {
              "type": "integer",
              "minimum": 2
            },
            "unsupported_provider_behavior": {
              "const": "config_blocker"
            }
          }
        },
        "candidate_findings_require_main_validation": {
          "const": true
        }
      }
    },
    "review_cycle_policy": {
      "type": "object",
      "required": [
        "control_reviewer_count",
        "control_review_trigger",
        "control_review_context_policy",
        "rerun_review_on",
        "rerun_scope",
        "materiality_classification"
      ],
      "additionalProperties": true,
      "properties": {
        "max_review_cycles": {
          "type": "integer",
          "minimum": 3
        },
        "control_reviewer_count": {
          "const": 2
        },
        "control_review_trigger": {
          "const": "rejected_or_downgraded_blocker_collision"
        },
        "control_review_context_policy": {
          "type": "object",
          "required": ["start_mode", "fork_conversation_context", "allowed_context_sources"],
          "additionalProperties": true,
          "properties": {
            "start_mode": {
              "const": "fresh_context"
            },
            "fork_conversation_context": {
              "const": false
            },
            "allowed_context_sources": {
              "type": "array",
              "items": {
                "enum": [
                  "disputed_blocker_findings",
                  "orchestrator_collision_reason",
                  "referenced_artifacts"
                ]
              },
              "minItems": 3,
              "uniqueItems": true
            }
          }
        },
        "rerun_review_on": {
          "type": "array",
          "items": {
            "enum": [
              "accepted_blocker_fixed",
              "project_overlay_materially_changed",
              "mandatory_evidence_added",
              "human_requested"
            ]
          },
          "allOf": [
            {"contains": {"const": "accepted_blocker_fixed"}},
            {"contains": {"const": "mandatory_evidence_added"}}
          ],
          "uniqueItems": true
        },
        "do_not_rerun_on": {
          "type": "array",
          "items": {"type": "string"}
        },
        "rerun_scope": {
          "type": "object",
          "required": [
            "after_validated_blocker_or_mandatory_evidence_gap",
            "full_scope_inputs",
            "reviewer_instruction_must_include",
            "closure_only_review_allowed",
            "closure_only_review_counts_as_acceptance_gate"
          ],
          "additionalProperties": true,
          "properties": {
            "after_validated_blocker_or_mandatory_evidence_gap": {
              "const": "full_scope_blocker_and_evidence_sweep"
            },
            "full_scope_inputs": {
              "type": "array",
              "items": {
                "enum": [
                  "latest_review_packet",
                  "complete_current_diff",
                  "latest_green_verification_evidence",
                  "previous_validated_findings_and_fixes"
                ]
              },
              "allOf": [
                {"contains": {"const": "latest_review_packet"}},
                {"contains": {"const": "complete_current_diff"}},
                {"contains": {"const": "latest_green_verification_evidence"}},
                {"contains": {"const": "previous_validated_findings_and_fixes"}}
              ],
              "uniqueItems": true
            },
            "reviewer_instruction_must_include": {
              "type": "array",
              "items": {
                "enum": [
                  "verify_closure_of_previous_validated_findings",
                  "search_for_new_or_remaining_p0_p1_blockers_across_full_slice",
                  "search_for_new_or_remaining_mandatory_evidence_gaps_across_full_slice"
                ]
              },
              "allOf": [
                {"contains": {"const": "verify_closure_of_previous_validated_findings"}},
                {"contains": {"const": "search_for_new_or_remaining_p0_p1_blockers_across_full_slice"}},
                {"contains": {"const": "search_for_new_or_remaining_mandatory_evidence_gaps_across_full_slice"}}
              ],
              "uniqueItems": true
            },
            "closure_only_review_allowed": {
              "type": "boolean"
            },
            "closure_only_review_counts_as_acceptance_gate": {
              "const": false
            }
          }
        },
        "materiality_classification": {
          "type": "object",
          "required": [
            "required_after_review_fixes",
            "material_triggers_take_precedence_over_do_not_rerun",
            "material_if_changes",
            "non_material_if_only"
          ],
          "additionalProperties": true,
          "properties": {
            "required_after_review_fixes": {"const": true},
            "material_triggers_take_precedence_over_do_not_rerun": {"const": true},
            "material_if_changes": {
              "type": "array",
              "items": {"type": "string"},
              "minItems": 1,
              "allOf": [
                {"contains": {"const": "task_contract_or_scope"}},
                {"contains": {"const": "selected_risk_surfaces_or_failure_path_matrix"}},
                {"contains": {"const": "behavior_bindings"}},
                {"contains": {"const": "affected_implementation_behavior"}},
                {"contains": {"const": "review_packet_content"}}
              ]
            },
            "non_material_if_only": {
              "type": "array",
              "items": {"type": "string"},
              "minItems": 1
            }
          }
        },
        "escalate_to_human_on": {
          "type": "array",
          "items": {"type": "string"}
        }
      }
    },
    "authority_policy": {
      "type": "object",
      "additionalProperties": true
    },
    "artifact_policy": {
      "type": "object",
      "required": ["structured_command_evidence_required", "evidence_freshness"],
      "additionalProperties": true,
      "properties": {
        "structured_command_evidence_required": {
          "const": true
        },
        "evidence_freshness": {
          "type": "object",
          "required": [
            "material_change_id_required",
            "green_gate_after_latest_material_change_required",
            "review_packet_after_latest_green_gate_required",
            "stale_evidence_must_be_marked_or_excluded"
          ],
          "additionalProperties": true,
          "properties": {
            "material_change_id_required": {"const": true},
            "green_gate_after_latest_material_change_required": {"const": true},
            "review_packet_after_latest_green_gate_required": {"const": true},
            "stale_evidence_must_be_marked_or_excluded": {"const": true}
          }
        }
      }
    },
    "decision_log": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "question", "answer", "status", "source"],
        "additionalProperties": true,
        "properties": {
          "id": {"type": "string"},
          "question": {"type": "string"},
          "answer": {},
          "status": {
            "type": "string",
            "enum": ["confirmed", "defaulted", "recommended", "unresolved", "rejected"]
          },
          "source": {
            "type": "string",
            "enum": ["human-dialogue", "agent-recommendation", "project-evidence", "default-policy"]
          }
        }
      }
    },
    "unresolved_questions": {
      "type": "array",
      "items": {"type": "string"}
    }
  }
}
