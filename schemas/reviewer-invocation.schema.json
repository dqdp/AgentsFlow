{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/agentsflow/reviewer-invocation.schema.json",
  "title": "Reviewer Invocation Metadata",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "provider",
    "reviewer_role",
    "billing_mode",
    "api_key_usage_forbidden",
    "context_policy",
    "forbidden_env_checked",
    "command",
    "wrapper",
    "provider_config_path",
    "provider_config_hash",
    "execution_mode",
    "permission_mode",
    "prompt_transport",
    "sandbox_mode",
    "tools",
    "output_format",
    "requested_model",
    "requested_effort",
    "input_hash",
    "prompt_hash",
    "review_prompt_contract_hash",
    "role_contract_hash",
    "rubric_hash",
    "schema_hash",
    "started_at",
    "finished_at",
    "exit_code",
    "raw_output_path",
    "raw_output_hash",
    "normalized_output_path",
    "normalized_output_hash"
  ],
  "properties": {
    "provider": {
      "const": "claude-code"
    },
    "reviewer_role": {
      "type": "string"
    },
    "billing_mode": {
      "const": "subscription-local"
    },
    "api_key_usage_forbidden": {
      "const": true
    },
    "context_policy": {
      "type": "object",
      "required": ["start_mode", "fork_conversation_context", "session_persistence"],
      "additionalProperties": true,
      "properties": {
        "start_mode": {
          "const": "fresh_context"
        },
        "fork_conversation_context": {
          "const": false
        },
        "session_persistence": {
          "const": false
        },
        "input_mode": {
          "type": "string"
        }
      }
    },
    "forbidden_env_checked": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "command": {
      "type": "string"
    },
    "wrapper": {
      "const": "scripts/reviewers/run_external_reviewer.py"
    },
    "provider_config_path": {
      "type": "string",
      "minLength": 1
    },
    "provider_config_hash": {
      "type": "string"
    },
    "execution_mode": {
      "enum": ["real", "mock"]
    },
    "permission_mode": {
      "const": "default"
    },
    "prompt_transport": {
      "enum": ["stdin", "file"]
    },
    "sandbox_mode": {
      "const": "require_escalated"
    },
    "tools": {
      "enum": ["", "Read"]
    },
    "output_format": {
      "const": "json"
    },
    "requested_model": {
      "const": "opus"
    },
    "requested_effort": {
      "const": "max"
    },
    "provider_models_used": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "provider_model_usage": {
      "type": "object",
      "additionalProperties": true
    },
    "provider_total_cost_usd": {
      "type": "number"
    },
    "provider_service_tier": {
      "type": "string"
    },
    "provider_speed": {
      "type": "string"
    },
    "max_turns": {
      "type": "integer"
    },
    "timeout_seconds": {
      "type": "integer"
    },
    "input_hash": {
      "type": "string"
    },
    "prompt_hash": {
      "type": "string"
    },
    "review_prompt_contract_hash": {
      "type": "string"
    },
    "role_contract_hash": {
      "type": "string"
    },
    "rubric_hash": {
      "type": "string"
    },
    "schema_hash": {
      "type": "string"
    },
    "started_at": {
      "type": "string"
    },
    "finished_at": {
      "type": "string"
    },
    "exit_code": {
      "type": "integer"
    },
    "raw_output_path": {
      "type": "string"
    },
    "raw_output_hash": {
      "type": "string"
    },
    "normalized_output_path": {
      "type": "string"
    },
    "normalized_output_hash": {
      "type": "string"
    },
    "normalization": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "method": {
          "enum": [
            "native-json",
            "deterministic-extraction",
            "orchestrator-extraction",
            "model-structured-extraction"
          ]
        },
        "source_path": {
          "type": "string"
        },
        "source_hash": {
          "type": "string"
        },
        "output_path": {
          "type": "string"
        },
        "output_hash": {
          "type": "string"
        },
        "schema_validation": {
          "const": "passed"
        },
        "normalized_by": {
          "type": "string"
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "prompt_transport": {"const": "stdin"}
        },
        "required": ["prompt_transport"]
      },
      "then": {
        "properties": {
          "tools": {"const": ""}
        }
      }
    },
    {
      "if": {
        "properties": {
          "prompt_transport": {"const": "file"}
        },
        "required": ["prompt_transport"]
      },
      "then": {
        "properties": {
          "tools": {"const": "Read"}
        }
      }
    }
  ]
}
