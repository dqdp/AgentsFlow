{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/agentsflow/reviewer-invocation.schema.json",
  "title": "Reviewer Invocation Metadata",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "provider",
    "reviewer_role",
    "billing_mode",
    "api_key_usage_forbidden",
    "context_policy",
    "command",
    "started_at",
    "finished_at",
    "exit_code"
  ],
  "properties": {
    "provider": {
      "type": "string"
    },
    "reviewer_role": {
      "type": "string"
    },
    "billing_mode": {
      "const": "subscription-local"
    },
    "api_key_usage_forbidden": {
      "const": true
    },
    "context_policy": {
      "type": "object",
      "required": ["start_mode", "fork_conversation_context", "session_persistence"],
      "additionalProperties": true,
      "properties": {
        "start_mode": {
          "const": "fresh_context"
        },
        "fork_conversation_context": {
          "const": false
        },
        "session_persistence": {
          "const": false
        },
        "input_mode": {
          "type": "string"
        }
      }
    },
    "forbidden_env_checked": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "command": {
      "type": "string"
    },
    "permission_mode": {
      "type": "string"
    },
    "output_format": {
      "type": "string"
    },
    "max_turns": {
      "type": "integer"
    },
    "timeout_seconds": {
      "type": "integer"
    },
    "input_hash": {
      "type": "string"
    },
    "prompt_hash": {
      "type": "string"
    },
    "review_prompt_contract_hash": {
      "type": "string"
    },
    "role_contract_hash": {
      "type": "string"
    },
    "rubric_hash": {
      "type": "string"
    },
    "schema_hash": {
      "type": "string"
    },
    "started_at": {
      "type": "string"
    },
    "finished_at": {
      "type": "string"
    },
    "exit_code": {
      "type": "integer"
    },
    "raw_output_path": {
      "type": "string"
    },
    "normalized_output_path": {
      "type": "string"
    }
  }
}
