{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AgentsFlow Review Prompt Contract",
  "type": "object",
  "required": [
    "version",
    "artifact_kind",
    "identity",
    "inputs",
    "reviewer_set",
    "context_policy",
    "permission_policy",
    "prompt_components",
    "prompt_policy",
    "rendered_prompts",
    "validation"
  ],
  "additionalProperties": true,
  "properties": {
    "version": {
      "type": "integer"
    },
    "artifact_kind": {
      "const": "review_prompt_contract"
    },
    "artifact_scope": {
      "type": "string",
      "enum": ["template", "example", "run"],
      "default": "run"
    },
    "identity": {
      "type": "object",
      "required": [
        "run_id",
        "workflow",
        "phase_id",
        "review_profile",
        "composition",
        "primary_gate"
      ],
      "additionalProperties": true,
      "properties": {
        "run_id": {
          "type": "string"
        },
        "workflow": {
          "type": "string"
        },
        "phase_id": {
          "type": "string"
        },
        "review_profile": {
          "type": "string",
          "enum": [
            "homogeneous-dual",
            "homogeneous-plus-focused",
            "heterogeneous-variable",
            "collision-control"
          ]
        },
        "composition": {
          "type": "string",
          "enum": [
            "homogeneous",
            "homogeneous-plus-focused",
            "heterogeneous",
            "control"
          ]
        },
        "primary_gate": {
          "type": "boolean"
        }
      }
    },
    "inputs": {
      "type": "object",
      "required": [
        "review_packet_schema",
        "review_packets",
        "output_schema"
      ],
      "additionalProperties": true,
      "properties": {
        "review_packet_schema": {
          "type": "string"
        },
        "review_packets": {
          "type": "array",
          "minItems": 1,
          "maxItems": 8,
          "items": {
            "type": "object",
            "required": [
              "reviewer",
              "path",
              "schema",
              "packet_hash"
            ],
            "additionalProperties": true,
            "properties": {
              "reviewer": {
                "type": "string"
              },
              "path": {
                "type": "string"
              },
              "schema": {
                "type": "string"
              },
              "packet_hash": {
                "type": "string"
              },
              "shared_packet_content_hash": {
                "type": "string"
              }
            }
          }
        },
        "output_schema": {
          "type": "string"
        }
      }
    },
    "reviewer_set": {
      "type": "array",
      "minItems": 1,
      "maxItems": 8,
      "items": {
        "type": "object",
        "required": [
          "instance_id",
          "role_id",
          "role_contract",
          "independent"
        ],
        "additionalProperties": true,
        "properties": {
          "instance_id": {
            "type": "string"
          },
          "role_id": {
            "type": "string"
          },
          "role_contract": {
            "type": "string"
          },
          "independent": {
            "type": "boolean"
          },
          "focus_zone": {
            "type": "object"
          }
        }
      }
    },
    "context_policy": {
      "type": "object",
      "required": ["start_mode", "fork_conversation_context", "allowed_context_sources"],
      "additionalProperties": true,
      "properties": {
        "start_mode": {
          "const": "fresh_context"
        },
        "fork_conversation_context": {
          "const": false
        },
        "allowed_context_sources": {
          "type": "array",
          "items": {
            "enum": ["review_packet", "referenced_artifacts"]
          },
          "minItems": 2,
          "maxItems": 2,
          "uniqueItems": true
        }
      }
    },
    "permission_policy": {
      "type": "object",
      "required": ["read_only", "forbidden_actions"],
      "additionalProperties": true,
      "properties": {
        "read_only": {
          "const": true
        },
        "forbidden_actions": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        }
      }
    },
    "prompt_components": {
      "type": "object",
      "required": [
        "shared_base_instructions",
        "finding_lifecycle",
        "output_instructions"
      ],
      "additionalProperties": true,
      "properties": {
        "shared_base_instructions": {
          "type": "string"
        },
        "finding_lifecycle": {
          "type": "string"
        },
        "output_instructions": {
          "type": "string"
        }
      }
    },
    "prompt_policy": {
      "type": "object"
    },
    "rendered_prompts": {
      "type": "array",
      "minItems": 1,
      "maxItems": 8,
      "items": {
        "type": "object",
        "required": [
          "reviewer",
          "prompt_path",
          "prompt_hash",
          "packet_hash",
          "schema_hash",
          "rubric_hash",
          "role_contract_hash"
        ],
        "additionalProperties": true,
        "properties": {
          "reviewer": {
            "type": "string"
          },
          "prompt_path": {
            "type": "string"
          },
          "prompt_hash": {
            "type": "string"
          },
          "shared_prompt_content_hash": {
            "type": "string"
          },
          "packet_hash": {
            "type": "string"
          },
          "shared_packet_content_hash": {
            "type": "string"
          },
          "schema_hash": {
            "type": "string"
          },
          "rubric_hash": {
            "type": "string"
          },
          "role_contract_hash": {
            "type": "string"
          }
        }
      }
    },
    "collision_control": {
      "type": ["object", "null"],
      "required": [
        "trigger",
        "disputed_finding_id",
        "original_severity",
        "source_reviewer_report",
        "orchestrator_rejection_reason",
        "evidence_references_checked"
      ],
      "additionalProperties": true,
      "properties": {
        "trigger": {
          "const": "rejected_blocker_finding_collision"
        },
        "disputed_finding_id": {
          "type": "string"
        },
        "original_severity": {
          "enum": ["P0", "P1"]
        },
        "orchestrator_rejection_reason": {
          "type": "string"
        },
        "source_reviewer_report": {
          "type": "string"
        },
        "evidence_references_checked": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        }
      }
    },
    "validation": {
      "type": "object",
      "required": ["schema", "assembly_invariants"],
      "additionalProperties": true,
      "properties": {
        "schema": {
          "type": "string"
        },
        "assembly_invariants": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
